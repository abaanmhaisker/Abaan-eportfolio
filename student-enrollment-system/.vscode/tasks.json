{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Local Server",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "http.server",
        "8080"
      ],
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Serving HTTP",
          "endsPattern": "^Serving HTTP"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
